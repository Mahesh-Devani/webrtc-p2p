# Ignore node_modules
node_modules/

# SSL certs for local HTTPS dev server
*.pem
*.key
*.crt
*.pfx
ca.key
ca.crt
cert.key
cert.crt
cert.pfx

# Ignore build output
dist/
build/

# Ignore logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Ignore editor files
.vscode/
.idea/
*.swp
*.swo

# Ignore OS files
.DS_Store
Thumbs.db

# Ignore environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Ignore temporary files
*.tmp
*.log
*.lock

# Ignore coverage directory
coverage/

# Ignore other common ignores
*.bak
*.orig
*.rej
*.swp
*.swo
*.pyc
*.pyo
